# ─────────────────────────────────────────────────────────────
# Mantra IMIS — Supabase Configuration Template
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp config/supabase.example.env config/supabase.env
# 2. Fill in your real values below
# 3. NEVER commit config/supabase.env to git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL
# Find it at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon (public) key — safe to use in frontend
# Find it at: Supabase Dashboard → Settings → API → Project API Keys → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# ─────────────────────────────────────────────────────────────
# After filling in the above values, update src/index.html:
#
#   Search for:  const SB_URL = 'YOUR_SUPABASE_URL';
#   Replace with: const SB_URL = 'https://your-project-ref.supabase.co';
#
#   Search for:  const SB_KEY = 'YOUR_SUPABASE_ANON_KEY';
#   Replace with: const SB_KEY = 'eyJhbGci...your-key...';
# ─────────────────────────────────────────────────────────────

# IMPORTANT: Never use the service_role key in frontend code.
# The anon key is safe. The service_role key bypasses all RLS
# policies and must only be used in secure server-side code.
